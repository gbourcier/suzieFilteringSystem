# suzieFilteringSystem — environment variables
# Copy to .env (gitignored), fill in real values, never commit secrets.

# ── IMAP (source mailbox) ────────────────────────────────────────────────────
IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_USER=owner@example.com
IMAP_PASS=changeme

# Folder to monitor (default: INBOX)
IMAP_FOLDER=INBOX

# Optional: comma-separated sender addresses to summarize; all others are
# archived and recorded but marked out_of_scope.  Empty = summarize all.
IMAP_ALLOWLIST=board@condo.tld

# ── SMTP (digest outbound) ───────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=digest@example.com
SMTP_PASS=changeme
SMTP_FROM=digest@example.com
DIGEST_TO=owner@example.com

# ── Ollama (local LLM) ───────────────────────────────────────────────────────
# Inside docker-compose: http://ollama:11434
# Dev harness (host Ollama): http://localhost:11434
OLLAMA_URL=http://ollama:11434

# Pinned after validation against the real mailbox corpus.
OLLAMA_MODEL=qwen2.5:14b

# Per-message inference budget. CPU inference on the lab box can take minutes.
LLM_TIMEOUT=10m

# ── Digest behaviour ─────────────────────────────────────────────────────────
# Language for the summary sentences in the digest (fr | en).
# Decide after running the dev harness; pin here.
SUMMARY_LANGUAGE=fr

# Cron expressions (America/Toronto by default)
POLL_SCHEDULE=0 7 * * *
DIGEST_SCHEDULE=0 8 * * 1

# Maximum characters of body text sent to the LLM (to keep CPU inference fast)
BODY_CHAR_LIMIT=4000

# ── Storage ──────────────────────────────────────────────────────────────────
DB_PATH=/data/digestd.db
ARCHIVE_DIR=/data/archive

# ── Runtime ──────────────────────────────────────────────────────────────────
TZ=America/Toronto
LOG_LEVEL=info
